SELECT item_name, price
FROM superstore 
ORDER BY price ASC; 

SELECT SUM(price)
FROM superstore;

SELECT AVG(price) 
FROM superstore;

SELECT MAX(price)
FROM superstore; 

SELECT MIN(price) 
FROM superstore;

SELECT COUNT(item_name) 
FROM superstore; 

SELECT MAX(price)
FROM superstore
WHERE category='Kitchen Supplies';

SELECT category, AVG(price)
FROM superstore GROUP BY category
ORDER BY AVG(price) DESC; 
-- category with highest avg item

SELECT category, SUM(price) 
FROM superstore GROUP BY category
ORDER BY SUM(price) DESC;
--category with lowest revenue
